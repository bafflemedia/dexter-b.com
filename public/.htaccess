# ----------------------------------------------------------------------
# 1. HOSTINGER / NODE.JS PASSENGER CONFIG (Preserved from Server)
# ----------------------------------------------------------------------
PassengerAppRoot /home/u501702799/domains/dexter-b.com/nodejs
PassengerAppType node
PassengerNodejs /opt/alt/alt-nodejs24/root/bin/node
PassengerStartupFile server.js
PassengerBaseURI /
PassengerRestartDir /home/u501702799/domains/dexter-b.com/nodejs/tmp
SetEnv LSNODE_CONSOLE_LOG console.log
RewriteRule ^\.builds - [F,L]

# ----------------------------------------------------------------------
# 2. SEO & CANONICALIZATION
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Keep public traffic canonical before it reaches Passenger.
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^(.*)$ https://www.dexter-b.com/$1 [L,R=301]
</IfModule>

# React SPA fallback and API routing are handled by Express in server.js.
# Do not rewrite /login, /bats, or /api/* to /index.html here; that bypasses
# Passenger/Express and can break both the landing page and protected routes.
